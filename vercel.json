{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/kommo-webhook", "dest": "/api/kommo-webhook.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/test-chat", "dest": "/api/test-chat.js" },
    { "src": "/api/fix-old-links", "dest": "/api/fix-old-links.js" },
    { "src": "/api/operator-sync", "dest": "/api/operator-sync.js" }
  ]
}
