# Required for AI replies
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_REPLY_MODEL=gpt-5-mini
MODEL_TIMEOUT_MS=10000

# Required for Kommo
KOMMO_TOKEN=
KOMMO_API_BASE=https://nakipoglu.kommo.com

# Required for Meta webhook verification, if used
META_VERIFY_TOKEN=

# Required to protect internal/cron endpoints (operator-sync, fix-old-links)
# Bu tanımlı değilse bu endpoint'ler tamamen kilitlenir (401 döner).
CRON_SECRET=

# Chat policy rollout
# current = eski canlı davranış, v2 = V2 policy canlı.
# POLICY_VERSION=v2 ve allowlist'ler boşsa tüm trafik V2 çalışır.
# Allowlist doldurulursa sadece listedeki lead/contact ID'ler V2 çalışır.
POLICY_VERSION=current
POLICY_V2_TEST_LEAD_IDS=
POLICY_V2_TEST_CONTACT_IDS=

# Optional logging / order sync
GOOGLE_LOG_WEBHOOK_URL=
GOOGLE_LOG_SECRET=
GOOGLE_ORDER_WEBHOOK_URL=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=logs

# Optional fallback providers, only if enabled
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
CLASSIFIER_MODEL=deepseek-chat
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
